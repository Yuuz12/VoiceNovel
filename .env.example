# 当前生效的 TTS provider：volcano（火山方舟）| mimo（小米 MIMO）
TTS_PROVIDER=volcano

# 火山方舟 TTS（原「方舟 Agent Plan」豆包 seed-tts-2.0，也可在前端设置页配置）
ARK_TTS_API_KEY=
ARK_TTS_RESOURCE_ID=seed-tts-2.0
# ARK_TTS_BASE_URL=  可选，默认 Agent Plan 专属地址

# 小米 MIMO TTS（MiMo-V2.5-TTS 系列，OpenAI 兼容，也可在前端设置页配置）
# MIMO_API_KEY=
# 模式：preset（预置音色）| voicedesign（文本描述定制）| voiceclone（音频样本复刻）

# OpenAI 兼容 LLM 配置（也可在前端设置页配置）
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
# 单次 LLM 请求超时（秒，默认 300=5 分钟；长文本按块各自计时）
LLM_TIMEOUT_SECONDS=300

# 服务器端口
PORT=3000

# 数据目录（相对项目根）
DATA_DIR=./data
